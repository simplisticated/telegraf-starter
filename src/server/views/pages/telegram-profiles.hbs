<div class="container mx-auto px-4 py-6">

    <h1 class="text-xl font-semibold mb-4 text-gray-100">
        Users
    </h1>

    <div
        class="overflow-x-auto bg-gray-900 rounded-xl shadow border border-gray-800"
    >
        <table class="min-w-full divide-y divide-gray-800">

            <thead class="bg-gray-800">
                <tr>
                    <th
                        class="px-6 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider"
                    >
                        ID
                    </th>
                    <th
                        class="px-6 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider"
                    >
                        Username
                    </th>
                    <th
                        class="px-6 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider"
                    >
                        Full name
                    </th>
                    <th
                        class="px-6 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider"
                    >
                        Is premium
                    </th>
                    <th
                        class="px-6 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider"
                    >
                        Bots
                    </th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-800">

                {{#each data.telegramProfiles}}
                    <tr class="hover:bg-gray-800/60 transition">
                        <td class="px-6 py-4 text-sm text-gray-200">
                            {{telegram_id}}
                        </td>

                        <td class="px-6 py-4 text-sm">
                            {{#if username}}
                                <a
                                    href="https://t.me/{{username}}"
                                    class="text-blue-400 hover:text-blue-300 hover:underline"
                                >
                                    @{{username}}
                                </a>
                            {{else}}
                                <span class="text-gray-500">No</span>
                            {{/if}}
                        </td>

                        <td class="px-6 py-4 text-sm">
                            {{first_name}} {{last_name}}
                        </td>

                        <td class="px-6 py-4">
                            {{#if is_premium}}
                                <span
                                    class="inline-flex px-2 py-1 rounded-full text-xs font-medium bg-emerald-900/40 text-emerald-300 border border-emerald-800"
                                >
                                    Yes
                                </span>
                            {{else}}
                                <span
                                    class="inline-flex px-2 py-1 rounded-full text-xs font-medium bg-gray-800 text-gray-400 border border-gray-700"
                                >
                                    No
                                </span>
                            {{/if}}
                        </td>

                        <td class="px-6 py-4 text-sm">
                            {{#each users}}
                              <p>
                                <a href="https://t.me/{{bot.username}}" class="text-blue-400 hover:text-blue-300 hover:underline">
                                  @{{bot.username}}
                                </a>
                              </p>
                            {{/each}}
                        </td>
                    </tr>
                {{/each}}

            </tbody>

        </table>
    </div>

</div>